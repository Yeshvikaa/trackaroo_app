<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#D1E8FF"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Back and Title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <ImageView
                android:id="@+id/backButton"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginTop="10dp"
                android:src="@drawable/ic_back"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Emergency"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#243B86"
                android:paddingBottom="4dp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333333"
            android:layout_marginBottom="16dp" />

        <!-- Emergency Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Emergency"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Emergency Contacts Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_box"
            android:padding="12dp"
            android:layout_marginBottom="24dp">

            <!-- Police -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#000000"
                    android:text="Police"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="100"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:layout_marginEnd="12dp" />

                <ImageView
                    android:id="@+id/callpolice"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/call_green"
                    android:contentDescription="Call Police" />
            </LinearLayout>

            <!-- Ambulance -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#000000"
                    android:text="Ambulance"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="108"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:layout_marginEnd="12dp" />

                <ImageView
                    android:id="@+id/callambulance"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/call_green"
                    android:contentDescription="Call Ambulance" />
            </LinearLayout>

            <!-- Fire Service -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Fire service"
                    android:textColor="#000000"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="101"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:layout_marginEnd="12dp" />

                <ImageView
                    android:id="@+id/callfireservice"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/call_green"
                    android:contentDescription="Call Fire" />
            </LinearLayout>
        </LinearLayout>

        <!-- Quick Actions -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quick actions"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- Send Alert Button -->
        <Button
            android:id="@+id/sendalert"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Send alert to all"
            android:backgroundTint="#FF6B6B"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- Contact Driver -->
        <Button
            android:id="@+id/contactDriver"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Contact driver"
            android:backgroundTint="#D1C4FF"
            android:textColor="#000000"
            android:layout_marginBottom="12dp" />

        <!-- Add Contacts -->
        <Button
            android:id="@+id/addContacts"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="+ Add contacts"
            android:backgroundTint="#4B68B3"
            android:textColor="#FFFFFF" />
    </LinearLayout>
</ScrollView>
