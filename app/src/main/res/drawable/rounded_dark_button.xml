<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">

    <!-- Dark background -->
    <solid android:color="#A6A5F8" />

    <!-- Optional white border -->
    <stroke
        android:width="2dp"
        android:color="#FFFFFF" />

    <!-- Size to keep it circular -->
    <size
        android:width="80dp"
        android:height="80dp" />

    <!-- Smooth corners -->
    <corners android:radius="40dp" />

</shape>
